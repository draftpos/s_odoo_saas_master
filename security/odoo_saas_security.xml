<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    
        <!-- Module category is still valid -->
        <record id="module_category_odoo_saas" model="ir.module.category">
            <field name="name">Odoo SaaS</field>
            <field name="description">Odoo SaaS</field>
            <field name="sequence">7</field>
        </record>
    
        <!-- SaaS User Group -->
        <record id="group_odoo_saas_user" model="res.groups">
            <field name="name">User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- SaaS Manager Group -->
        <record id="group_odoo_saas_manager" model="res.groups">
            <field name="name">Administrator</field>
            <field name="implied_ids" eval="[(4, ref('group_odoo_saas_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
        
        <!-- SaaS Master Group -->
        <record id="group_odoo_saas_master" model="res.groups">
            <field name="name">SaaS Master</field>
            <field name="implied_ids" eval="[(4, ref('group_odoo_saas_manager'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="comment">This role has exclusive access to sensitive security keys and certificates.</field>
        </record>
    
    </data>
</odoo>
