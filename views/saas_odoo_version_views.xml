<?xml version="1.0" encoding="UTF-8"?>
<odoo>

	<record id="saas_odoo_version_view_tree" model="ir.ui.view">
        <field name="name">saas.odoo.version.view.tree</field>
        <field name="model">saas.odoo.version</field>
        <field name="arch" type="xml">
            <list string="SaaS Odoo Version">
            	<field name="sequence" widget="handle"/>
                <field name="name"/>
            </list>
        </field>
    </record>
    
    <record id="saas_odoo_version_view_form" model="ir.ui.view">
        <field name="name">saas.odoo.version.view.form</field>
        <field name="model">saas.odoo.version</field>
        <field name="arch" type="xml">
            <form string="Odoo Version">
                <sheet>
                	<div name="button_box" position="inside">
                        <button class="oe_stat_button" type="object"
                            name="action_view_odoo_version_config"
                            icon="fa-gear"
                            groups="s_odoo_saas_master.group_odoo_saas_manager">
                            <div class="o_stat_info">
                                <span>Odoo Config</span>
                            </div>
                        </button>
                    </div>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>                    
                    <div class="oe_title">
                        <label for="name" string="Name"/>
                        <h1>
                            <div class="d-flex">
                                <field class="text-break" name="name" options="{'line_breaks': False}" widget="text" />
                            </div>
                        </h1>
                    </div>
                    <group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="saas_odoo_version_view_search" model="ir.ui.view">
        <field name="name">saas.odoo.version.view.search</field>
        <field name="model">saas.odoo.version</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <separator/>
                <filter name="ftr_archived" string="Archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
    
    <record id="saas_odoo_version_action" model="ir.actions.act_window">
        <field name="name">Odoo Versions</field>
        <field name="res_model">saas.odoo.version</field>
        <field name="view_mode">list,form</field>
    </record>
    
    <menuitem id="saas_odoo_version_menu" action="saas_odoo_version_action" parent="saas_config_odoo_menu" sequence="10"/>

</odoo>
