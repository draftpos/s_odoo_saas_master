<?xml version="1.0" encoding="UTF-8"?>
<odoo>

	<record id="saas_odoo_instance_docker_compose_volume_view_tree" model="ir.ui.view">
        <field name="name">saas.odoo.instance.docker.compose.volume.view.tree</field>
        <field name="model">saas.odoo.instance.docker.compose.volume</field>
        <field name="arch" type="xml">
            <list string="SaaS Odoo Instance Docker Compose Volume">
                <field name="container_id" string="Container"/>
   				<field name="name" string="Name"/>                    				
   				<field name="volume_type" string="Type"/>
   				<field name="container_path"/>
   				<field name="storage_path"/>
            </list>
        </field>
    </record>
    
    <record id="saas_odoo_instance_docker_compose_volume_action" model="ir.actions.act_window">
        <field name="name">Volumes</field>
        <field name="res_model">saas.odoo.instance.docker.compose.volume</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
