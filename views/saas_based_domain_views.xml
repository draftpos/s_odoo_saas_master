<?xml version="1.0" encoding="UTF-8"?>
<odoo>

	<record id="saas_based_domain_view_tree" model="ir.ui.view">
        <field name="name">saas.based.domain.view.tree</field>
        <field name="model">saas.based.domain</field>
        <field name="arch" type="xml">
            <list string="SaaS Based Domain">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="forward_ip"/>
                <field name="reverse_ip"/>
            </list>
        </field>
    </record>
    
    <record id="saas_based_domain_view_form" model="ir.ui.view">
        <field name="name">saas.based.domain.view.form</field>
        <field name="model">saas.based.domain</field>
        <field name="arch" type="xml">
            <form string="Based Domain">
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>                    
                    <div class="oe_title">
                        <label for="name" string="Name"/>
                        <h1>
                            <div class="d-flex">
                                <field class="text-break" name="name" options="{'line_breaks': False}" widget="text" />
                            </div>
                        </h1>
                    </div>
                    <group>
                    	<group>
                    		<field name="forward_ip"/>
                			<field name="reverse_ip"/>
                    	</group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="saas_based_domain_view_search" model="ir.ui.view">
        <field name="name">saas.based.domain.view.search</field>
        <field name="model">saas.based.domain</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <separator/>
                <filter name="ftr_archived" string="Archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
    
    <record id="saas_based_domain_action" model="ir.actions.act_window">
        <field name="name">Based Domains</field>
        <field name="res_model">saas.based.domain</field>
        <field name="view_mode">list,form</field>
    </record>
    
    <menuitem id="saas_based_domain_menu" action="saas_based_domain_action" parent="saas_config_domain_menu" sequence="10"/>

</odoo>
