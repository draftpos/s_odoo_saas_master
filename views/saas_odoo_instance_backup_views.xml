<?xml version="1.0" encoding="UTF-8"?>
<odoo>

	<record id="saas_odoo_instance_backup_view_tree" model="ir.ui.view">
        <field name="name">saas.odoo.instance.backup.view.tree</field>
        <field name="model">saas.odoo.instance.backup</field>
        <field name="arch" type="xml">
            <list string="SaaS Odoo Instance Backup">
                <field name="name" />
				<field name="datetime" />
				<field name="format" />
				<field name="file_size" />
				<field name="description" />
            </list>
        </field>
    </record>
    
    <record id="saas_odoo_instance_backup_view_form" model="ir.ui.view">
        <field name="name">saas.odoo.instance.backup.view.form</field>
        <field name="model">saas.odoo.instance.backup</field>
        <field name="arch" type="xml">
            <form string="SaaS Odoo Instance Backup">
            	<header>
					<button name="action_download" string="Download" type="object" class="btn-primary" groups="s_odoo_saas_master.group_odoo_saas_user"/>
				</header>
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>                    
                    <div class="oe_title">
                        <label for="name" string="Name"/>
                        <h1>
                            <div class="d-flex">
                                <field class="text-break" name="name" options="{'line_breaks': False}" widget="text" />
                            </div>
                        </h1>
                    </div>
                    <group>
                    	<group>
                    		<field name="file_path"/>
							<field name="file_size" />
                    	</group>
                    	<group>
                    		<field name="datetime"/>
							<field name="format" />
							<field name="instance_id"/>
                    	</group>
                    </group>
                    <separator string="Description" />
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>
    

    
    <record id="saas_odoo_instance_backup_action" model="ir.actions.act_window">
        <field name="name">Backups</field>
        <field name="res_model">saas.odoo.instance.backup</field>
        <field name="context">{'search_default_grb_odoo_instance': 1}</field>
        <field name="view_mode">list,form</field>
    </record>
    
    <menuitem id="saas_odoo_instance_backup_menu" action="saas_odoo_instance_backup_action" parent="saas_menu_odoo_instance" sequence="50"/>

</odoo>
