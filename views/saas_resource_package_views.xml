<?xml version="1.0" encoding="UTF-8"?>
<odoo>

	<record id="saas_resource_package_view_tree" model="ir.ui.view">
        <field name="name">saas.resource.package.view.tree</field>
        <field name="model">saas.resource.package</field>
        <field name="arch" type="xml">
            <list string="SaaS Resource Package">
                <field name="name"/>
            </list>
        </field>
    </record>
    
    <record id="saas_resource_package_view_form" model="ir.ui.view">
        <field name="name">saas.resource.package.view.form</field>
        <field name="model">saas.resource.package</field>
        <field name="arch" type="xml">
            <form string="SaaS Resource Package">
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>                    
                    <div class="oe_title">
                        <label for="name" string="Name"/>
                        <h1>
                            <div class="d-flex">
                                <field class="text-break" name="name" options="{'line_breaks': False}" widget="text" />
                            </div>
                        </h1>
                    </div>
                    <notebook>
                    	<page name="line" string="Package Lines">
                    		<field name="line_ids">
                    			<list editable="bottom">
                    				<field name="type"/>
                    				<field name="name"/>
                    				<field name="value"/>
                    			</list>
                    		</field>
                    	</page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="saas_resource_package_view_search" model="ir.ui.view">
        <field name="name">saas.resource.package.view.search</field>
        <field name="model">saas.resource.package</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <separator/>
                <filter name="ftr_archived" string="Archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
    
    <record id="saas_resource_package_action" model="ir.actions.act_window">
        <field name="name">Resource Packages</field>
        <field name="res_model">saas.resource.package</field>
        <field name="view_mode">list,form</field>
    </record>
    
    <menuitem id="saas_resource_package_menu" action="saas_resource_package_action" parent="saas_menu_config" sequence="100"/>

</odoo>
