<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="saas_product_template_form_view" model="ir.ui.view">
        <field name="name">saas_product_template_form_view</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <group name="sale" position="after">
                <group name="saas_info" string="SaaS App Information"
                	invisible="not can_be_user_app">
                    <field name="technical_name"/>
                    <field name="ecom_category_id"/>
                    <field name="required_product_ids" widget="many2many_tags"/>
                    <field name="dependent_product_ids" widget="many2many_tags"/>
                </group>
            </group>
            <div name="options" position="inside">
            	<span class="d-inline-block">
                    <field name="can_be_user_app"/>
                    <label for="can_be_user_app"/>
                </span>
            </div>
        </field>
    </record>

    
</odoo>
