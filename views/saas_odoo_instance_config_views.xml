<?xml version="1.0" encoding="UTF-8"?>
<odoo>

	<record id="saas_odoo_instance_config_view_tree" model="ir.ui.view">
        <field name="name">saas.odoo.instance.config.view.tree</field>
        <field name="model">saas.odoo.instance.config</field>
        <field name="arch" type="xml">
            <list string="SaaS Odoo Instance Config">
                <field name="name"/>
                <field name="value"/>
                <field name="section_id"/>
            </list>
        </field>
    </record>
    
    <record id="saas_odoo_instance_config_view_form" model="ir.ui.view">
        <field name="name">saas.odoo.instance.config.view.form</field>
        <field name="model">saas.odoo.instance.config</field>
        <field name="arch" type="xml">
            <form string="Odoo Instance Config">
                <sheet>
                    <group>
                    	<group>
                    		<field name="name"/>
                    		<field name="value"/>
                    	</group>
                    	<group>
                    		<field name="section_id"/>
                    		<field name="instance_id"/>
                    		<field name="odoo_version_id"/>
                    	</group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    

    
    <record id="saas_odoo_instance_config_action" model="ir.actions.act_window">
        <field name="name">Odoo Instance Config</field>
        <field name="res_model">saas.odoo.instance.config</field>
        <field name="context">{'search_default_grb_odoo_instance': 1}</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
