<?xml version="1.0" encoding="UTF-8"?>
<odoo>

	<record id="saas_odoo_instance_docker_container_view_tree" model="ir.ui.view">
        <field name="name">saas.odoo.instance.docker.container.view.tree</field>
        <field name="model">saas.odoo.instance.docker.container</field>
        <field name="arch" type="xml">
            <list string="SaaS Odoo Instance Docker Container">
                <field name="name"/>
 				<field name="image"/>
 				<field name="ports"/>
 				<field name="state" />
 				<button icon="fa-refresh" string="Restart" type="object" name="action_restart" invisible="state != 'run'"/>
 				<button icon="fa-stop-circle" string="Stop" type="object" name="action_stop" invisible="state != 'run'"/>
 				<button icon="fa-play-circle" string="Start" type="object" name="action_start" invisible="state != 'stop'"/>
            </list>
        </field>
    </record>
    
    <record id="saas_odoo_instance_docker_container_view_form" model="ir.ui.view">
        <field name="name">saas.odoo.instance.docker.container.view.form</field>
        <field name="model">saas.odoo.instance.docker.container</field>
        <field name="arch" type="xml">
            <form string="SaaS Nginx">
            	<header>
            		<button string="Restart" type="object" name="action_restart" class="btn-primary" invisible="state != 'run'"/>
            		<button string="Stop" type="object" name="action_stop" invisible="state != 'run'"/>
            		<button string="Start" type="object" name="action_start" class="btn-primary" invisible="state != 'stop'"/>
                	<field name="state" widget="statusbar" />
                </header>
                <sheet>
                	<group>
      					<group>
      						<field name="name"/>
      						<field name="image"/>
      					</group>
      					<group>
      						<field name="ports"/>
      					</group>
      				</group>
      				<separator string="Volumes"/>
            		<field name="docker_compose_volume_ids">
            			<list editable="bottom">
            				<field name="name" string="Name"/>                    				
            				<field name="volume_type" string="Type"/>
            				<field name="container_path"/>
            				<field name="storage_path"/>
            			</list>
            		</field>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="saas_odoo_instance_docker_container_action" model="ir.actions.act_window">
        <field name="name">Containers</field>
        <field name="res_model">saas.odoo.instance.docker.container</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
