<?xml version="1.0" encoding="UTF-8"?>
<odoo>

	<record id="saas_odoo_instance_port_view_tree" model="ir.ui.view">
        <field name="name">saas.odoo.instance.port.view.tree</field>
        <field name="model">saas.odoo.instance.port</field>
        <field name="arch" type="xml">
            <list string="SaaS Odoo Instance Port">
                <field name="name"/>
                <field name="port"/>
                <field name="pserver_id"/>
                <field name="instance_id"/>
                <field name="based_domain_id"/>
            </list>
        </field>
    </record>
    

    
    <record id="saas_odoo_instance_port_action" model="ir.actions.act_window">
        <field name="name">Odoo Instance Ports</field>
        <field name="res_model">saas.odoo.instance.port</field>
        <field name="context">{'search_default_grb_instance': 1}</field>
        <field name="view_mode">list</field>
    </record>
    
    <menuitem id="saas_odoo_instance_port" action="saas_odoo_instance_port_action" parent="saas_menu_odoo_instance" sequence="20"/>

</odoo>
