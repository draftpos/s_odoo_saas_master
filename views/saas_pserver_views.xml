<?xml version="1.0" encoding="UTF-8"?>
<odoo>

	<record id="saas_pserver_view_tree" model="ir.ui.view">
        <field name="name">saas.pserver.view.tree</field>
        <field name="model">saas.pserver</field>
        <field name="arch" type="xml">
            <list string="SaaS PServer">
                <field name="name"/>
                <field name="ssh_port"/>
                <field name="version_16_plus"/>
                <field name="ssh_keypair_id" groups="s_odoo_saas_master.group_odoo_saas_master"/>
            </list>
        </field>
    </record>
    
    <record id="saas_pserver_view_form" model="ir.ui.view">
        <field name="name">saas.pserver.view.form</field>
        <field name="model">saas.pserver</field>
        <field name="arch" type="xml">
            <form string="SaaS Physical Server">
                <field name="active" invisible="1"/>
                <header>
                	<button string="Test Connection" type="object" name="action_test_connection" class="btn-primary"/>
                </header>
                <sheet>
                    <field name="can_edit_ssh_key" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="alert alert-warning mb-3" groups="!s_odoo_saas_master.group_odoo_saas_master">
                        <span>SSH Key Pair configuration is only accessible to users with SaaS Master role. Contact your SaaS Master for any SSH key configurations.</span>
                    </div>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. Production Server"/></h1>
                    </div>
                    <group>                        
                        <group>                        	
                        	<field name="ssh_keypair_id" groups="s_odoo_saas_master.group_odoo_saas_master"/>
                        	<field name="ssh_port"/>
                        </group>
                        <group>
                        	<field name="version_16_plus"/>
                        </group>
                    </group>
                    <notebook>
                    	<page name='ips' string="IPs">
                    		<field name="ip_ids">
                    			<list editable="bottom">
                    				<field name="name"/>
                    				<field name="ip_v6"/>
                    				<field name="is_public"/>
                    				<field name="type"/>
                    			</list>
                    		</field>
                    	</page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="saas_pserver_view_search" model="ir.ui.view">
        <field name="name">saas.pserver.view.search</field>
        <field name="model">saas.pserver</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <separator/>
                <filter name="ftr_archived" string="Archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
    
    <record id="saas_pserver_action" model="ir.actions.act_window">
        <field name="name">Physical Servers</field>
        <field name="res_model">saas.pserver</field>
        <field name="view_mode">list,form</field>
    </record>
    
    <menuitem id="saas_pserver_menu" action="saas_pserver_action" parent="saas_config_server_menu" sequence="10"/>

</odoo>
