<?xml version="1.0" encoding="UTF-8"?>
<odoo>

	<record id="saas_odoo_instance_installed_app_view_tree" model="ir.ui.view">
        <field name="name">saas.odoo.instance.installed.app.view.tree</field>
        <field name="model">saas.odoo.instance.installed.app</field>
        <field name="arch" type="xml">
            <list string="SaaS Odoo Instance Installed App" editable="bottom">
                <field name="name"/>
                <field name="technical_name"/>
                <field name="product_id"/>
 				<field name="installed_date" />
 				<field name="not_paid"/>
            </list>
        </field>
    </record>
    
    <record id="saas_odoo_instance_installed_app_view_form" model="ir.ui.view">
        <field name="name">saas.odoo.instance.installed.app.view.form</field>
        <field name="model">saas.odoo.instance.installed.app</field>
        <field name="arch" type="xml">
            <form string="SaaS Odoo Instance Installed App">
                <sheet>
                	<group>
      					<group>
      						<field name="name"/>
      						<field name="technical_name"/>
      						<field name="installed_date"/>
      					</group>
      					<group>
      						<field name="product_id"/>
      						<field name="not_paid"/>
      					</group>
      				</group>
                </sheet>
            </form>
        </field>
    </record>
    

    
    <record id="saas_odoo_instance_installed_app_action" model="ir.actions.act_window">
        <field name="name">Installed Apps</field>
        <field name="res_model">saas.odoo.instance.installed.app</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
