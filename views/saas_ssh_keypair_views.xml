<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="saas_ssh_keypair_view_list" model="ir.ui.view">
        <field name="name">saas.ssh.keypair.view.list</field>
        <field name="model">saas.ssh.keypair</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="type"/>
            </list>
        </field>
    </record>

    <record id="saas_ssh_keypair_view_form" model="ir.ui.view">
        <field name="name">saas.ssh.keypair.view.form</field>
        <field name="model">saas.ssh.keypair</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>

                    <field name="active" invisible="1"/>
                    <field name="can_edit_private_key" invisible="1"/>

                    <div groups="!s_odoo_saas_master.group_odoo_saas_master" class="alert alert-info" role="alert">
                        <span><strong>Note:</strong> Only SaaS Master users can modify the private key. Contact your SaaS Master if you need changes.</span>
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Production Key" required="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="public_key_id" invisible="1"/>
                            <field name="private_key_id" invisible="1"/>
                            <field name="type"/>
                        </group>
                        <group groups="s_odoo_saas_master.group_odoo_saas_master">
                            <field name="private_key_filename" invisible="1"/>
                            <field name="private_key_data" filename="private_key_filename" string="Private Key File"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="saas_ssh_keypair_action" model="ir.actions.act_window">
        <field name="name">SSH Key Pair</field>
        <field name="res_model">saas.ssh.keypair</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first SSH Key Pair
            </p>
        </field>
    </record>

    <menuitem id="saas_ssh_keypair_menu"
              action="saas_ssh_keypair_action"
              parent="saas_menu_config"
              sequence="10"/>

</odoo>