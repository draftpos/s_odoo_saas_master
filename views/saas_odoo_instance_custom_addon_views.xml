<?xml version="1.0" encoding="UTF-8"?>
<odoo>

	<record id="saas_odoo_instance_custom_addon_view_tree" model="ir.ui.view">
        <field name="name">saas.odoo.instance.custom.addon.view.tree</field>
        <field name="model">saas.odoo.instance.custom.addon</field>
        <field name="arch" type="xml">
            <list string="SaaS Odoo Instance Custom Addon">
                <field name="name" />
				<field name="instance_id" />
				<field name="addon_path"/>
				<field name="container_path"/>
				<field name="cloned"/>
            </list>
        </field>
    </record>
    
    <record id="saas_odoo_instance_custom_addon_view_form" model="ir.ui.view">
		<field name="name">saas.odoo.instance.custom.addon.view.form</field>
		<field name="model">saas.odoo.instance.custom.addon</field>
		<field name="type">form</field>
		<field name="arch" type="xml">
			<form string="Custom Addon">
				<header>
                       <button name="action_clone" type="object" string="Clone" class="oe_highlight" invisible="cloned" />
                       <button name="action_pull" type="object" string="Pull" class="oe_highlight" invisible="not cloned" />
                       <button name="action_remove" type="object" string="Remove" invisible="not cloned"
                       	confirm="This will be drop all data of the custom addon. Are you sure you want to remove?"
						groups="s_odoo_saas_master.group_odoo_saas_manager"/>
                   </header>
				<sheet>
					<group>
						<group>
							<field name="instance_id" readonly="cloned" options="{'no_create': True}"/>
							<field name="url" widget="url"/>
							<field name="name" readonly="cloned"/>
							<field name="addon_path"/>
							<field name="container_path"/>
						</group>
						<group>
							<field name="clone_uri" readonly="cloned"/>
							<field name="branch" readonly="cloned"/>
							<field name="cloned"/>
						</group>
					</group>
				</sheet>
			</form>
		</field>
	</record>
	

	
	<record id="saas_odoo_instance_custom_addon_action" model="ir.actions.act_window">
		<field name="name">Custom Addons</field>
		<field name="type">ir.actions.act_window</field>
		<field name="res_model">saas.odoo.instance.custom.addon</field>
		<field name="context">{'search_default_grp_instance': 1}</field>
		<field name="view_mode">list,form</field>
	</record>
	
	<menuitem id="saas_odoo_instance_custom_addon_menu" action="saas_odoo_instance_custom_addon_action" parent="saas_menu_odoo_instance" sequence="15"/>

</odoo>
