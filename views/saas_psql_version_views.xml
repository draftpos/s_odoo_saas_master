<?xml version="1.0" encoding="UTF-8"?>
<odoo>

	<record id="saas_psql_version_view_tree" model="ir.ui.view">
        <field name="name">saas.psql.version.view.tree</field>
        <field name="model">saas.psql.version</field>
        <field name="arch" type="xml">
            <list string="SaaS PSQL Version">
                <field name="name"/>
                <field name="docker_image_tag"/>
            </list>
        </field>
    </record>
    
    <record id="saas_psql_version_view_form" model="ir.ui.view">
        <field name="name">saas.psql.version.view.form</field>
        <field name="model">saas.psql.version</field>
        <field name="arch" type="xml">
            <form string="PSQL Version">
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>                    
                    <div class="oe_title">
                        <label for="name" string="Name"/>
                        <h1>
                            <div class="d-flex">
                                <field class="text-break" name="name" options="{'line_breaks': False}" widget="text" />
                            </div>
                        </h1>
                    </div>
                    <group>
                    	<group>
                    		<field name="docker_image_tag"/>
                    	</group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="saas_psql_version_view_search" model="ir.ui.view">
        <field name="name">saas.psql.version.view.search</field>
        <field name="model">saas.psql.version</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <separator/>
                <filter name="ftr_archived" string="Archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
    
    <record id="saas_psql_version_action" model="ir.actions.act_window">
        <field name="name">PSQL Versions</field>
        <field name="res_model">saas.psql.version</field>
        <field name="view_mode">list,form</field>
    </record>
    
    <menuitem id="saas_psql_version_menu" action="saas_psql_version_action" parent="saas_menu_config" sequence="20"/>

</odoo>
