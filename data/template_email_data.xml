<?xml version='1.0' encoding='utf-8'?>
<odoo noupdate="1">

    <record id="deploy_instance_mail_template" model="mail.template">
        <field name="name">Deploy Odoo Instance</field>
        <field name="model_id" ref="model_saas_odoo_instance"/>
        <field name="subject">Deploy Odoo instance successfully</field>
        <field name="email_from">"{{ (object.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ object.partner_id.email_formatted }}</field>
        <field name="body_html" type="html">
            <div>
                <a href="https://skyerp.net">
                    <img border="0" src="/s_odoo_saas_master/static/src/img/skyerp.png" alt="image" target="_blank" style="width:202px; height: 88px;"/> ​
                </a>
                <hr width="100%" style="background-color:#1A82A1; border:none; height:3px; margin: 16px 0px 16px 0px;"/>
            </div>

            <div>
                <div style="text-align:center; font-size:18px; color:#fcb042;"><strong>CONGRATULATIONS</strong></div>
                <div style="text-align:center; font-size:18px; color:#fcb042;"><strong>ON YOUR SUCCESSFUL TRIAL REGISTRATION</strong></div>
            </div>
            <br/>
            <div>
                <p><span>Your instance&#160;</span><span><u><span t-out="object.url or ''"></span></u></span><span>&#160;has been initialized successfully</span></p>
                <ul>
                    <li><strong>URL:&#160;</strong><u><span t-out="object.url or ''"></span></u></li>
                    <li><strong>Login/Email:&#160;</strong>admin</li>
                    <li><strong>Password:&#160;</strong>admin</li>
                </ul>
                <p>Please change the default password to secure information in your system..</p>
            </div>
            <div>
                <div>During use, if you have any questions or need help, please refer to the following links for assistance.</div>
            </div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>
    
