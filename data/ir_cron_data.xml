<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record forcecreate="True" id="cron_saas_auto_backup" model="ir.cron">
            <field name="name">SaaS Master: Auto backup cron</field>
            <field name="model_id" ref="model_saas_odoo_instance"/>
            <field name="state">code</field>
            <field name="code">model.cron_auto_backup()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="datetime.now().strftime('%Y-%m-%d 17:20:00')"/>
        </record>

